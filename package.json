{
  "name": "saucedemo_ts_project",
  "version": "1.0.0",
  "description": "Playwright TypeScript automation project for SauceDemo",
  "main": "index.js",
  "scripts": {
    "test": "playwright test --grep-invert @visual",
    "test:smoke": "playwright test --grep @smoke --grep-invert @visual",
    "test:regression": "playwright test --grep @regression --grep-invert @visual",
    "test:visual": "playwright test --grep @visual",
    "test:visual:update": "playwright test --grep @visual --update-snapshots",
    "test:all": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:chrome": "playwright test --project=chromium",
    "test:edge": "playwright test --project=msedge",
    "report": "playwright show-report",
    "clean": "rimraf test-results playwright-report allure-results"
  },
  "keywords": [
    "playwright",
    "typescript",
    "automation",
    "testing",
    "e2e",
    "visual-regression"
  ],
  "author": "leonovvc",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "dotenv": "^16.3.1",
    "rimraf": "^5.0.5"
  }
}